---
import Layout from '../layouts/Layout.astro';
---

<Layout title="PB Notes | Purpose & Peace">
	<main class="flex flex-col items-center justify-center min-h-[80vh] text-center px-4">
		<h1 class="text-5xl md:text-7xl font-bold text-white mb-6">PB Notes</h1>
		<p class="mb-10 text-lg text-white/90 max-w-2xl">
			A space for everyone seeking to grow deeper in faith and walk in their true calling. 
			From navigating relationships to spiritual challenges, we explore what it means 
			to live fully for Christ today.
		</p>
		<div class="flex gap-4">
			<a href="/blog" class="bg-white text-black px-8 py-3 rounded-full font-bold hover:bg-gray-200 transition">
				Explore My Notes
			</a>
		</div>
	</main>
</Layout>
