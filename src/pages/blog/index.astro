---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('blog');
---

<Layout title="PB Notes | All Posts">
	<main class="max-w-5xl mx-auto px-4 py-12 text-white">
		<h1 class="text-4xl font-bold mb-8">Spiritual Notes</h1>
		<div class="grid gap-8">
			{posts.map((post) => (
				<a href={`/blog/${post.id}/`} class="block p-6 border border-white/10 rounded-xl hover:bg-white/5 transition">
					<h2 class="text-2xl font-bold mb-2">{post.data.title}</h2>
					<p class="text-gray-400 mb-4">{post.data.description}</p>
					<span class="text-sm text-gray-500">{post.data.pubDate.toLocaleDateString()}</span>
				</a>
			))}
		</div>
	</main>
</Layout>
